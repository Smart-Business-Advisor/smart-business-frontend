{
  "rewrites": [
    {
      "source": "/api/Account/:path*",
      "destination": "https://identitytemplateapi.runasp.net/api/Account/:path*"
    },
    {
      "source": "/api/ideas/:path*",
      "destination": "https://stratify.runasp.net/api/ideas/:path*"
    },
    {
      "source": "/api/Chat/:path*",
      "destination": "https://financeaiapi.runasp.net/api/Chat/:path*"
    },
    {
      "source": "/api/Stock/:path*",
      "destination": "https://financeaiapi.runasp.net/api/Stock/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}